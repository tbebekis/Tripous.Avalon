<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Tripous.Avalon.ucEditor">
    <DockPanel Margin="10">
        <Border Name="ToolBarContainer" DockPanel.Dock="Top" Classes="ToolbarContainer" >
            <StackPanel Name="pnlToolBar" Classes="ToolBar" Orientation="Horizontal" MinHeight="32">
            </StackPanel>
        </Border>
        <Border Name="GridContainer"  BorderBrush="Gray" BorderThickness="1">
            <AvaloniaEdit:TextEditor Name="TextEditor"  />
        </Border>
    </DockPanel>   
</UserControl>
