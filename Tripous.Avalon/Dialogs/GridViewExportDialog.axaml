<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Tripous.Avalon.GridViewExportDialog"
        Title="Export Settings"
        Width="550" 
        Height="470"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Bottom" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10" 
                    Margin="0,15,0,0">
            <Button Name="btnOK" Content="OK"  Click="AnyClick" IsDefault="True" />
            <Button Name="btnCancel" Content="Cancel"  Click="AnyClick" IsCancel="True" />
        </StackPanel>

        <TabControl>
            <TabItem Header="General" Name="tabGeneral">
                <StackPanel Margin="10" Spacing="20">
                    <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, Auto">
                        <TextBlock Grid.Row="0" Text="Format:" VerticalAlignment="Center" Margin="0,5"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Name="cboFormat" HorizontalAlignment="Stretch" Margin="0,5"/>

                        <TextBlock Grid.Row="1" Text="File Path:" VerticalAlignment="Center" Margin="0,5"/>
                        <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*, Auto" Margin="0,5">
                            <TextBox Name="edtExportFilePath" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Name="btnExportFilePath" Content="..."  Margin="2,0,0,0" Click="AnyClick" />
                        </Grid>
                    </Grid>

                    <Separator Height="1" Background="#EEE"/>

                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="General Options" FontWeight="Bold" Margin="0,0,0,5" Foreground="Gray" FontSize="12"/>
                            <CheckBox Name="chIncludeHeaders" Content="Include Headers" />
                            <CheckBox Name="chOnlyVisibleColumns" Content="Only Visible Columns" />
                            <CheckBox Name="chUseFormattedValues" Content="Use Formatted Values" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Grouping &amp; Totals" FontWeight="Bold" Margin="0,0,0,5" Foreground="Gray" FontSize="12"/>
                            <CheckBox Name="chIncludeGroups" Content="Include Groups" />
                            <CheckBox Name="chIncludeFooters" Content="Include Footers" />
                            <CheckBox Name="chIncludeGrandTotal" Content="Include Grand Total" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Data / Formatting" Name="tabData">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Grid ColumnDefinitions="150, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">
                            <TextBlock Grid.Row="0" Text="Culture:" VerticalAlignment="Center" Margin="0,3"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Name="cboCulture" HorizontalAlignment="Stretch" Margin="0,5"/>

                            <TextBlock Grid.Row="1" Text="DateTime Format:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Name="edtDateTimeFormat" Margin="0,3"/>

                            <TextBlock Grid.Row="2" Text="Number Format:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="edtNumberFormat" Margin="0,3"/>

                            <TextBlock Grid.Row="3" Text="Boolean True:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Name="edtBooleanTrueValue" Margin="0,3"/>

                            <TextBlock Grid.Row="4" Text="Boolean False:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Name="edtBooleanFalseValue" Margin="0,3"/>

                            <TextBlock Grid.Row="5" Text="Blob Mode:" VerticalAlignment="Center" Margin="0,3"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Name="cboBlobMode" HorizontalAlignment="Stretch" Margin="0,3"/>

                            <TextBlock Grid.Row="6" Text="Blob Placeholder:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="edtBlobPlaceholderText" Margin="0,3"/>

                            <TextBlock Grid.Row="7" Text="Memo Placeholder:" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Name="edtMemoPlaceholderText" Margin="0,3"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Format-specific" Name="tabSpecific">
                <StackPanel Margin="10" Spacing="20">
                    <Grid ColumnDefinitions="150, *" RowDefinitions="Auto, Auto, Auto, Auto">
                        <TextBlock Grid.Row="0" Text="Encoding:" VerticalAlignment="Center" Margin="0,3"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Name="cboEncoding" HorizontalAlignment="Stretch" Margin="0,3"/>

                        <TextBlock Grid.Row="1" Text="CSV Delimiter:" VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Name="edtCsvDelimiter" Margin="0,3"/>

                        <TextBlock Grid.Row="2" Text="HTML Title:" VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Name="edtHtmlTitle" Margin="0,3"/>

                        <TextBlock Grid.Row="3" Text="Excel Sheet Name:" VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Name="edtExcelSheetName" Margin="0,3"/>
                    </Grid>

                    <Separator Height="1" Background="#EEE"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Format Options" FontWeight="Bold" Margin="0,0,0,5" Foreground="Gray" FontSize="12"/>
                        <CheckBox Name="chIndentJson" Content="Indent JSON Output" />
                        <CheckBox Name="chCsvQuoteAll" Content="CSV: Quote All Fields" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>