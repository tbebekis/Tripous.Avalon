<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DbPark.DbConnectionDialog"
        Title="Database Connection"
        Width="400" 
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Connection Name:" />
        <TextBox Name="edtName" />

        <TextBlock Text="Database Type:" />
        <ComboBox Name="cboDbType" HorizontalAlignment="Stretch" />
        
        <TextBlock Text="Command Timeout (seconds):" FontWeight="SemiBold"/>
        <NumericUpDown Name="numTimeout" 
                       Minimum="5" 
                       Maximum="3600" 
                       Increment="1" 
                       Value="30" />

        <TextBlock Text="Connection String:" />
        <TextBox Name="edtConnectionString" TextWrapping="Wrap" AcceptsReturn="True" Height="80"  Watermark="Server=...;Database=...;" />
 
        <Grid Margin="0,20,0,0">
            <Button Name="btnCheckIsOk" Content="Check" HorizontalAlignment="Left" Click="AnyClick" />
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Spacing="10">
                <Button Name="btnOK" Content="OK" Click="AnyClick" IsDefault="True" />
                <Button Name="btnCancel" Content="Cancel" Click="AnyClick" IsCancel="True" />
            </StackPanel>
        </Grid>        
    </StackPanel>
</Window>
