<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PivotTestApp10.MainWindow"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Title="PivotTestApp10">
        
        <DockPanel Margin="10">
                <Border DockPanel.Dock="Top" Classes="ToolbarContainer" Background="#F0F0F0" Margin="0,0,0,5">
                        <StackPanel Name="pnlToolBar" Classes="ToolBar" Orientation="Horizontal" MinHeight="32">
                        </StackPanel>
                </Border>
                
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                        <Button x:Name="btnTest" Content="Test" Click="AnyClick" />
                        <Button x:Name="btnTest2" Content="Test 2" Click="AnyClick" />
                </StackPanel>

                <Border BorderBrush="Gray" BorderThickness="1">
                        <DataGrid Name="Grid" IsReadOnly="True" GridLinesVisibility="All" />
                </Border>
        </DockPanel>          
 
</Window>
