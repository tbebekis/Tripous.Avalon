<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Tripous.Avalon.RowFilterItemDialog"
        Width="500" 
        MinWidth="450"
        MaxWidth="800"
        MaxHeight="1000"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
        
        <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
                        <Button Name="btnOK" Content="OK"  Click="AnyClick" IsDefault="True"/>
                        <Button Name="btnCancel" Content="Cancel" Click="AnyClick" IsCancel="True"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlFilterItem" Spacing="15" Margin="0,0,10,0"/>
                </ScrollViewer>
        </DockPanel>        
 
</Window>
